{
  "services": {
    "github": {
      "enabled": true,
      "device_code_url": "https://github.com/login/device",
      "browser": "Chrome",
      "timeout": 300,
      "auto_authorize": true
    },
    "google": {
      "enabled": true,
      "device_code_url": "https://google.com/device",
      "browser": "Chrome",
      "timeout": 300,
      "auto_authorize": true
    },
    "anthropic": {
      "enabled": true,
      "token_endpoint": "https://api.anthropic.com/oauth/token",
      "browser": "Chrome",
      "timeout": 300,
      "auto_authorize": true
    },
    "openai": {
      "enabled": true,
      "token_endpoint": "https://api.openai.com/oauth/token",
      "browser": "Chrome",
      "timeout": 300,
      "auto_authorize": true
    },
    "slack": {
      "enabled": true,
      "oauth_url": "https://slack.com/oauth/v2/authorize",
      "browser": "Chrome",
      "timeout": 300,
      "auto_authorize": false
    },
    "linear": {
      "enabled": true,
      "oauth_url": "https://linear.app/oauth/authorize",
      "browser": "Chrome",
      "timeout": 300,
      "auto_authorize": false
    },
    "atlassian": {
      "enabled": true,
      "oauth_url": "https://auth.atlassian.com/authorize",
      "browser": "Chrome",
      "timeout": 300,
      "auto_authorize": false
    }
  },
  "daemon": {
    "port": 8000,
    "host": "127.0.0.1",
    "log_level": "INFO",
    "cache_dir": "~/.cache/auth-daemon"
  },
  "browser": {
    "default": "Chrome",
    "options": [
      "Chrome",
      "Google Chrome",
      "Safari",
      "Firefox"
    ]
  },
  "patterns": {
    "github": {
      "device_code": "[A-Z0-9]{4}-[A-Z0-9]{4}",
      "success": "Device activation complete",
      "failure": "Device code has expired"
    },
    "google": {
      "device_code": "[A-Z0-9]{8,}",
      "success": "Device activation successful",
      "failure": "Device code is invalid"
    }
  },
  "accessibility": {
    "enabled": true,
    "button_click_timeout": 5,
    "text_input_timeout": 3
  }
}
